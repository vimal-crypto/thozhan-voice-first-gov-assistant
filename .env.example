# .env.example
# Copy this file to .env and add your actual API keys

# ========================================
# Groq API Key (REQUIRED)
# ========================================
# Get your FREE API key from: https://console.groq.com/
# Steps:
# 1. Sign up for a free Groq account
# 2. Go to API Keys section
# 3. Create a new API key
# 4. Copy the key and paste it below

GROQ_API_KEY=your_groq_api_key_here

# ========================================
# Instructions
# ========================================
# After adding your API key:
# 1. Rename this file from .env.example to .env
#    OR
# 2. Create a new file named .env and copy your key there
# 3. Never commit .env file to git (it's already in .gitignore)

# Note: Groq offers a generous FREE tier for testing and development
